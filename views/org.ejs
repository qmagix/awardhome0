<%- include('partials/header') %>
<div class="container">
  <div class="header-section">
    <h1><%= org.name %></h1>
    <% if (org.slogan) { %>
      <p class="subtitle" style="color: var(--accent-gold); font-size: 1.2rem; margin-top: -0.5rem; font-weight: 500;"><%= org.slogan %></p>
    <% } %>
    <p class="subtitle">Events & Competitions (<%= eventsCount %> Total)</p>
    <% if (org.description) { %>
      <div style="max-width: 800px; margin: 1rem auto 1.5rem auto; color: var(--text-color); line-height: 1.6; background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); text-align: left;">
        <%= org.description %>
      </div>
    <% } %>
    <% if (org.website) { %>
      <a href="<%= org.website %>" target="_blank" style="color: var(--primary);">Visit Official Website</a>
    <% } %>
  </div>
  
  <h2 style="margin-bottom: 1.5rem;">Events Archive</h2>
  
  <% if (eventsCount === 0) { %>
    <p>No events found for this organization yet.</p>
  <% } else { %>
    <!-- Yearly Tabs -->
    <div class="tabs-container">
      <ul class="year-tabs" id="yearTabs">
        <% groupedData.forEach(function(yearGroup, index) { %>
          <li class="tab-item <%= index === 0 ? 'active' : '' %>" data-target="year-<%= yearGroup.year %>">
            <%= yearGroup.year %> (<%= yearGroup.events.length %>)
          </li>
        <% }); %>
      </ul>
    </div>

    <!-- Year Content Sections -->
    <div class="tab-content-container" style="margin-top: 2rem;">
      <% groupedData.forEach(function(yearGroup, index) { %>
        <div class="tab-pane <%= index === 0 ? 'active' : '' %>" id="year-<%= yearGroup.year %>">
          <div class="grid">
            <% yearGroup.events.forEach(function(event) { %>
              <div class="card glass-card" style="display: flex; flex-direction: column; justify-content: space-between;">
                <div>
                  <h3 style="margin-top: 0;"><%= event.name %></h3>
                  <p style="color: var(--text-muted); margin-bottom: 0.5rem;"><i class="fas fa-calendar-alt"></i> <%= event.date_string %></p>
                </div>
                <div style="margin-top: 1.5rem;">
                  <a href="/event/<%= event.id %>" class="btn" style="width: 100%; text-align: center;">View Event Awards &rarr;</a>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab-item');
    const panes = document.querySelectorAll('.tab-pane');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Remove active class from all tabs & panes
        tabs.forEach(t => t.classList.remove('active'));
        panes.forEach(p => p.classList.remove('active'));

        // Add active class to clicked tab
        tab.classList.add('active');
        
        // Show corresponding pane
        const targetId = tab.getAttribute('data-target');
        const targetPane = document.getElementById(targetId);
        if (targetPane) {
          targetPane.classList.add('active');
        }
      });
    });
  });
</script>

<%- include('partials/footer') %>
