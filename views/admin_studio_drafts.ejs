<%- include('partials/header') %>
<div class="container" style="margin-top: 4rem;">
  <div class="header-section">
    <h1>Pending Studio Data Drafts</h1>
    <p class="subtitle">Review and verify automated scraped data before merging.</p>
  </div>

  <% if (drafts.length === 0) { %>
    <div class="card glass-card" style="margin-top: 2rem; text-align: center; padding: 3rem;">
      <h3 style="color: var(--text-muted);">No pending drafts.</h3>
      <p>Run the bootstrapper script to find more data!</p>
    </div>
  <% } else { %>
    <% drafts.forEach(function(draft) { %>
      <div class="card glass-card" style="margin-top: 2rem;">
        <h2 style="margin-top: 0; color: var(--primary);">
          <a href="/studio/<%= draft.studio_id %>" style="color: inherit; text-decoration: none;"><%= draft.current_name %></a>
        </h2>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem;">
          Source: <a href="<%= draft.source_url %>" target="_blank" style="color: var(--primary);"><%= draft.source_url %></a><br>
          Scraped on: <%= new Date(draft.created_at).toLocaleString() %>
        </p>

        <form action="/admin/studio-drafts/<%= draft.id %>/approve" method="POST">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 1.5rem;">
            <!-- Current Data -->
            <div style="background: rgba(255,255,255,0.02); padding: 1.5rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
              <h3 style="margin-top: 0; color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase;">Current Database</h3>
              
              <div style="margin-top: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.2rem;">Website URL</label>
                <div style="padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 4px; color: <%= draft.current_website_url ? 'white' : 'var(--text-muted)' %>;">
                  <%= draft.current_website_url || 'Empty' %>
                </div>
              </div>

              <div style="margin-top: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.2rem;">Email</label>
                <div style="padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 4px; color: <%= draft.current_email ? 'white' : 'var(--text-muted)' %>;">
                  <%= draft.current_email || 'Empty' %>
                </div>
              </div>

              <div style="margin-top: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.2rem;">Phone</label>
                <div style="padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 4px; color: <%= draft.current_phone ? 'white' : 'var(--text-muted)' %>;">
                  <%= draft.current_phone || 'Empty' %>
                </div>
              </div>

              <div style="margin-top: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.2rem;">Address</label>
                <div style="padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 4px; color: <%= draft.current_address ? 'white' : 'var(--text-muted)' %>;">
                  <%= draft.current_address || 'Empty' %>
                </div>
              </div>
            </div>

            <!-- Scraped Data -->
            <div style="background: rgba(16, 185, 129, 0.05); padding: 1.5rem; border-radius: 8px; border: 1px solid rgba(16, 185, 129, 0.2);">
              <h3 style="margin-top: 0; color: #10b981; font-size: 0.9rem; text-transform: uppercase;">Scraped Draft (Editable)</h3>
              
              <div style="margin-top: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: #10b981; margin-bottom: 0.2rem;">Website URL</label>
                <input type="text" name="website_url" value="<%= draft.scraped_website_url || '' %>" style="width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(16, 185, 129, 0.3); color: white; border-radius: 4px;">
              </div>

              <div style="margin-top: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: #10b981; margin-bottom: 0.2rem;">Email</label>
                <input type="text" name="email" value="<%= draft.scraped_email || '' %>" style="width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(16, 185, 129, 0.3); color: white; border-radius: 4px;">
              </div>

              <div style="margin-top: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: #10b981; margin-bottom: 0.2rem;">Phone</label>
                <input type="text" name="phone" value="<%= draft.scraped_phone || '' %>" style="width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(16, 185, 129, 0.3); color: white; border-radius: 4px;">
              </div>

              <div style="margin-top: 1rem;">
                <label style="display: block; font-size: 0.8rem; color: #10b981; margin-bottom: 0.2rem;">Address</label>
                <input type="text" name="address" value="<%= draft.scraped_address || '' %>" style="width: 100%; padding: 0.5rem; background: rgba(0,0,0,0.3); border: 1px solid rgba(16, 185, 129, 0.3); color: white; border-radius: 4px;">
              </div>
            </div>
          </div>

          <div style="display: flex; gap: 1rem; justify-content: flex-end; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem;">
            <button type="submit" class="btn" style="background: #10b981; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 600;">Merge & Approve</button>
            <button type="button" onclick="document.getElementById('reject-form-<%= draft.id %>').submit();" class="btn btn-secondary" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 600;">Reject Bad Data</button>
          </div>
        </form>

        <form id="reject-form-<%= draft.id %>" action="/admin/studio-drafts/<%= draft.id %>/reject" method="POST" style="display: none;"></form>
      </div>
    <% }); %>
  <% } %>
</div>
<%- include('partials/footer') %>
