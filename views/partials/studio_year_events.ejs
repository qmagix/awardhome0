<% events.forEach(function(event, eIndex) { %>
  <div class="accordion glass-card" style="margin-bottom: 1rem; padding: 0; overflow: hidden;">
    <div class="accordion-header"
      style="padding: 1.5rem; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02);">
      <h3 style="margin: 0; color: var(--text-color); font-size: 1.2rem;">🏆 <%= event.title %>
      </h3>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <span class="badge" style="background: rgba(236, 72, 153, 0.2); color: #f472b6;">
          <%= event.awards.length %> Awards
        </span>
        <span class="accordion-icon">▼</span>
      </div>
    </div>

    <div class="accordion-body">
      <div style="overflow-x: auto; margin-top: 1rem;">
        <table class="premium-table sortable-table">
          <thead>
            <tr>
              <th>Routine</th>
              <th>Award Type</th>
              <th>Place</th>
              <th>Category</th>
              <th>Dancer(s)</th>
            </tr>
          </thead>
          <tbody>
            <% event.awards.forEach(function(award) { %>
              <tr class="<%= isPremiumAward(award) ? 'premium-award-border' : '' %>">
                <td><strong>
                    <%= award.performance_name %>
                  </strong> <span class="sub-text">
                    <%= award.performance_number ? '#' + award.performance_number : '' %>
                  </span></td>
                <td>
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <% const customIconStudio = getCustomIcon(award, award.customIconsObj); %>
                    <% if (customIconStudio) { %>
                      <img src="<%= customIconStudio %>" alt="Icon" style="width: 20px; height: 20px; object-fit: contain;" title="<%= award.org_name %> Custom Icon">
                    <% } %>
                    <%= (award.award_type && award.award_type.trim() !== '') ? award.award_type : award.category %>
                  </div>
                </td>
                <td><span class="badge <%= isPremiumAward(award) ? 'badge-premium' : '' %>">
                    <%= isPremiumAward(award) ? getPremiumDetails(award).icon + ' ' : '' %><%= formatPlacement(award) %>
                  </span></td>
                <td>
                  <%= award.category || '-' %>
                </td>
                <td id="dancers-cell-<%= award.id %>">
                  <% if (award.dancers && award.dancers.length > 0) { %>
                    <% award.dancers.forEach(function(d, index) { %>
                      <% 
                        let badgeClass = 'badge-imported';
                        if (d.status === 'pending') badgeClass = 'badge-pending';
                        if (d.status === 'verified') badgeClass = 'badge-verified';
                      %>
                      <span class="badge-common <%= badgeClass %>">
                        <% if (d.unique_id) { %>
                          <a href="/dancer/<%= d.unique_id %>" style="color: inherit; text-decoration: none;"><%= d.name %></a>
                        <% } else { %>
                          <%= d.name %>
                        <% } %>
                      </span>
                    <% }); %>
                  <% } else { %>
                    <em style="color: var(--text-muted); margin-right: 8px;">Company / Group</em>
                  <% } %>
                  <button onclick="openClaimModal('<%= award.id %>')" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 4px; color: var(--text-muted); font-size: 0.75rem; padding: 2px 8px; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='rgba(236,72,153,0.2)'; this.style.color='white'" onmouseout="this.style.background='rgba(255,255,255,0.1)'; this.style.color='var(--text-muted)'">+ Add Me</button>
                </td>
              </tr>
              <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% }); %>
