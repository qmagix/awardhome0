<%- include('partials/header') %>
<div class="container" style="max-width: 600px; margin-top: 4rem;">
  <div class="card glass-card" style="padding: 2.5rem;">
    <h2 style="margin-top: 0; color: var(--primary);">Claim Studio</h2>
    <p style="color: var(--text-muted); margin-bottom: 2rem;">
      You are applying to claim and manage <strong><%= studio.name %></strong>.
    </p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem;">
        <%= error %>
      </div>
    <% } %>

    <form action="/claim/studio/<%= studio.id %>" method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
      <div>
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Your Role / Affiliation</label>
        <input type="text" name="role" required placeholder="e.g. Studio Director, Owner" style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white;">
      </div>
      <div>
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Phone Number</label>
        <input type="tel" name="phone" required placeholder="For verification purposes" style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white;">
      </div>
      <div>
        <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Additional Proof (Optional)</label>
        <textarea name="proof" rows="4" placeholder="Link to staff page showing your name, or any other verification details" style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white;"></textarea>
      </div>
      <button type="submit" class="btn" style="background: var(--primary); color: white; border: none; padding: 1rem; font-weight: 600; border-radius: 6px; cursor: pointer;">Submit Claim Request</button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
