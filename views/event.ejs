<%- include('partials/header') %>
<div class="container">
  <div class="header-section">
    <h1><%= event.org_name %> - <%= event.name %></h1>
    <p class="subtitle"><%= event.date_string %> (<%= event.year %>)</p>
  </div>
  
  <div class="admin-actions" style="margin-bottom: 3rem; padding: 1.5rem; background: rgba(0,0,0,0.2); border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h3 style="color: var(--primary); margin-bottom: 0.5rem; font-size: 1.2rem;">Data Integrity Sync</h3>
      <p style="color: var(--text-muted); margin: 0; font-size: 0.9rem;">Automatically link dancers to solo awards that only list the routine number by cross-referencing routine numbers with known dancers from the same studio.</p>
    </div>
    <form action="/admin/backfill-dancers/<%= event.id %>" method="POST" style="margin: 0;">
      <button type="submit" class="btn btn-warning">Run Backfill for this Event</button>
    </form>
  </div>

  <div class="awards-list">
    <% if (groupedAwards.length === 0) { %>
      <p>No awards found for this event.</p>
    <% } else { %>
      <% groupedAwards.forEach(function(group) { %>
        <h3 style="margin-top: 2.5rem; margin-bottom: 1rem; color: var(--primary);">
          <a href="/studio/<%= group.studioId %>" style="color: inherit; text-decoration: none;"><%= group.studioName %></a>
        </h3>
        <table class="premium-table sortable-table">
          <thead>
            <tr>
              <th>Routine</th>
              <th>Award Type</th>
              <th>Place</th>
              <th>Category</th>
              <th>Dancer(s)</th>
            </tr>
          </thead>
          <tbody>
            <% group.eventAwards.forEach(function(award) { %>
              <tr>
                <td><strong><%= award.performance_name %></strong> <span class="sub-text"><%= award.performance_number ? '#' + award.performance_number : '' %></span></td>
                <td><%= award.award_type %></td>
                <td><span class="badge"><%= award.place %></span></td>
                <td><%= award.category || '-' %></td>
                <td>
                  <% if (award.unique_id) { %>
                    <a href="/dancer/<%= award.unique_id %>" class="dancer-link"><%= award.dancer_name %></a>
                  <% } else if (award.dancer_name) { %>
                    <%= award.dancer_name %>
                  <% } else { %>
                    <em>Company / Group</em>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% }); %>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
