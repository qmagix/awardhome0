<%- include('partials/header') %>
<div class="container">
  <div class="profile-card glass-card">
    <div class="profile-header">
      <div class="avatar">💃</div>
      <div class="profile-info">
        <h1><%= dancer.name %></h1>
        <p class="studio-name">Affiliations: 
          <% dancer.studios.forEach((s, idx) => { %>
            <strong><a href="/studio/<%= s.id %>"><%= s.name %></a></strong><%= idx < dancer.studios.length - 1 ? ', ' : '' %>
          <% }); %>
        </p>
        <p class="unique-id">ID: <code><%= dancer.unique_id %></code></p>
      </div>
    </div>
  </div>

  <h2>Solo Awards</h2>
  <div class="awards-grid">
    <% if (awards.length === 0) { %>
      <p>No solo awards found.</p>
    <% } else { %>
      <% awards.forEach(function(award) { %>
        <div class="award-card glass-card">
          <div class="award-place"><%= award.place %></div>
          <h3><%= award.performance_name || 'N/A' %></h3>
          <p class="category"><%= award.award_type %></p>
          <% if (award.category) { %>
            <p class="sub-category">Category: <%= award.category %></p>
          <% } %>
          <p class="sub-category">🏆 <%= award.event_name %> (<%= award.event_year %>)</p>
          <span class="perf-num">Routine <%= award.performance_number ? '#' + award.performance_number : 'N/A' %></span>
        </div>
      <% }); %>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
