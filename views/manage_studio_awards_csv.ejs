<%- include('partials/header') %>

<div class="container" style="margin-top: 4rem;">
  <div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end;">
    <div>
      <a href="/manage/studio/<%= studio.id %>/awards" style="color: var(--text-muted); text-decoration: none; font-size: 0.9rem;">&larr; Back to Awards Editor</a>
      <h1 style="margin-top: 0.5rem;">Review Bulk Upload</h1>
      <p class="subtitle">Please review the awards below. Invalid rows will be skipped.</p>
    </div>
    
    <form action="/manage/studio/<%= studio.id %>/awards/csv-commit" method="POST">
      <input type="hidden" name="preview_data" value="<%= encodeURIComponent(JSON.stringify(previewData)) %>">
      <button type="submit" class="btn btn-primary" style="padding: 0.75rem 2rem; font-size: 1.1rem; font-weight: bold; background: var(--accent-gold); color: black; border: none; box-shadow: 0 4px 15px rgba(234, 179, 8, 0.4);">Confirm & Import Valid Awards</button>
    </form>
  </div>

  <div class="card glass-card" style="overflow-x: auto;">
    <table class="premium-table" style="width: 100%; min-width: 800px;">
      <thead>
        <tr>
          <th>Status</th>
          <th>Competition</th>
          <th>Year</th>
          <th>Routine Name</th>
          <th>Place</th>
          <th>Category</th>
          <th>Dancers</th>
        </tr>
      </thead>
      <tbody>
        <% let validCount = 0; let invalidCount = 0; %>
        <% previewData.forEach(row => { %>
          <% if (row.isValid) validCount++; else invalidCount++; %>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.1); <%= row.isValid ? '' : 'opacity: 0.5; background: rgba(239, 68, 68, 0.05);' %>">
            <td>
              <% if (row.isValid) { %>
                <span class="badge" style="background: rgba(16, 185, 129, 0.2); color: #10b981;">Ready</span>
              <% } else { %>
                <span class="badge" style="background: rgba(239, 68, 68, 0.2); color: #ef4444;" title="Missing: <%= row.missing.join(', ') %>">Skip: Missing Data</span>
              <% } %>
            </td>
            <td><%= row.event_name || '-' %></td>
            <td><%= row.year || '-' %></td>
            <td><%= row.performance_name || '-' %></td>
            <td><%= row.place || '-' %></td>
            <td><%= row.category || '-' %></td>
            <td>
              <% if (row.dancers && row.dancers.length > 0) { %>
                <div style="display: flex; flex-wrap: wrap; gap: 0.25rem;">
                  <% row.dancers.forEach(d => { %>
                    <% if (d.matched) { %>
                      <span class="badge" style="background: rgba(59, 130, 246, 0.2); color: #60a5fa;"><%= d.name %></span>
                    <% } else { %>
                      <span class="badge" style="background: rgba(245, 158, 11, 0.2); color: #f59e0b;" title="New dancer will be added to roster">✨ <%= d.name %> (New)</span>
                    <% } %>
                  <% }) %>
                </div>
              <% } else { %>
                <span style="color: var(--text-muted); font-style: italic;">None</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  
  <div style="margin-top: 1.5rem; display: flex; gap: 2rem; color: var(--text-muted);">
    <span><strong>Total Rows:</strong> <%= previewData.length %></span>
    <span style="color: #10b981;"><strong>Valid (Will Import):</strong> <%= validCount %></span>
    <% if (invalidCount > 0) { %>
      <span style="color: #ef4444;"><strong>Invalid (Will Skip):</strong> <%= invalidCount %></span>
    <% } %>
  </div>
</div>

<script>
  const form = document.querySelector('form');
  form.addEventListener('submit', function() {
    const hiddenInput = document.querySelector('input[name="preview_data"]');
    hiddenInput.value = decodeURIComponent(hiddenInput.value);
  });
</script>

<%- include('partials/footer') %>
