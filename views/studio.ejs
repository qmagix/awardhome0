<%- include('partials/header') %>

<style>
.badge-imported { background: rgba(59, 130, 246, 0.2); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2); }
.badge-pending { background: rgba(245, 158, 11, 0.2); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.2); }
.badge-verified { background: rgba(16, 185, 129, 0.2); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.2); }
.badge-common { padding: 2px 8px; border-radius: 12px; font-size: 0.8rem; display: inline-block; margin-right: 4px; margin-bottom: 4px; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>
  <div class="container">
    <% if (mergedIntoStudio) { %>
      <div style="background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.2); color: #60a5fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;">
        <span style="font-size: 2rem;">🔀</span>
        <div>
          <h3 style="margin: 0 0 0.25rem 0; color: white;">This studio profile has been merged.</h3>
          <p style="margin: 0;">This studio's records have been officially merged into <a href="/studio/<%= mergedIntoStudio.id %>" style="color: #93c5fd; font-weight: bold; text-decoration: underline;"><%= mergedIntoStudio.name %></a>. For a more complete picture, please view the main studio profile.</p>
        </div>
      </div>
    <% } %>
    
    <div class="header-section" style="display: flex; justify-content: space-between; align-items: flex-start;">
      <div style="display: flex; gap: 1.5rem; align-items: center;">
        <% if (studio.logo_url) { %>
          <img src="<%= studio.logo_url %>" alt="<%= studio.name %> logo" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid var(--primary);">
        <% } %>
        <div>
          <h1 style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem; margin-top: 0;">
            <%= studio.name %>
              <% if (studio.is_claimed) { %>
                <span class="badge"
                  style="background: rgba(16, 185, 129, 0.2); color: #10b981; font-size: 0.8rem; font-weight: 600; vertical-align: middle;">✓
                  Claimed</span>
                <% } %>
          </h1>
          <% if (studio.bio) { %>
            <p style="color: var(--text-muted); max-width: 600px; line-height: 1.5; margin: 0 0 0.5rem 0;"><%= studio.bio %></p>
          <% } else { %>
            <p class="subtitle" style="margin: 0 0 0.5rem 0;">Studio Award History</p>
          <% } %>
          <div style="font-size: 0.85rem; color: var(--text-muted); display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
            <span>👁️ <%= studio.view_count %> profile views</span>
            <% if (studio.website_url) { %>
              <span>🌐 <a href="<%= studio.website_url.startsWith('http') ? studio.website_url : 'https://' + studio.website_url %>" target="_blank" style="color: var(--primary);">Website</a></span>
            <% } %>
            <% if (studio.instagram_handle) { %>
              <% const igHandle = studio.instagram_handle.replace(/^@/, ''); %>
              <a href="https://instagram.com/<%= igHandle %>" target="_blank" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.2rem; color: white; background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: 600; font-size: 0.75rem;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                IG
              </a>
            <% } %>
            <% if (studio.tiktok_handle) { %>
              <% const ttHandle = studio.tiktok_handle.replace(/^@/, ''); %>
              <a href="https://tiktok.com/@<%= ttHandle %>" target="_blank" style="text-decoration: none; display: inline-flex; align-items: center; gap: 0.2rem; color: white; background: #000000; border: 1px solid rgba(255,255,255,0.2); padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: 600; font-size: 0.75rem;">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                TikTok
              </a>
            <% } %>
          </div>
        </div>
      </div>
      <div style="margin-top: 0.5rem;">
        <% if (studio.is_claimed) { %>
          <% if (typeof user !== 'undefined' && user && user.id === studio.owner_id) { %>
            <a href="/manage/studio/<%= studio.id %>" class="btn btn-secondary"
              style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; border-color: var(--primary); color: white; background: rgba(236, 72, 153, 0.1);">
              Manage Studio
            </a>
          <% } else if (typeof user === 'undefined' || !user) { %>
            <a href="/login" class="btn btn-secondary"
              style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none;">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z" />
              </svg>
              Owner Login
            </a>
          <% } %>
          <% } else { %>
            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem;">
              <div style="display: flex; align-items: center; gap: 1rem;">
                <a href="#" onclick="openBenefitsModal(event)"
                  style="color: var(--primary); text-decoration: underline; font-size: 0.95rem; font-weight: 600; transition: color 0.2s;">Why
                  Claim?</a>
                <a href="/claim/studio/<%= studio.id %>" class="btn"
                  style="background: var(--primary); color: white; border: none; padding: 0.5rem 1.5rem; font-weight: 600; border-radius: 8px; cursor: pointer; box-shadow: 0 4px 15px rgba(236, 72, 153, 0.3); text-decoration: none; display: inline-block;">Claim
                  Studio</a>
              </div>
              <p style="margin: 0; font-size: 0.85rem; color: var(--text-muted); max-width: 350px; text-align: right; line-height: 1.4;">Claim this studio to customize your dashboard metrics, update awards, correct dancer names, and embed your achievements!</p>
            </div>
            <% } %>
      </div>
    </div>

    <!-- Quick Stats -->
    <% const isOwnerOrAdmin = typeof user !== 'undefined' && user && (user.role === 'admin' || user.id === studio.owner_id); %>
    
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; margin-top: 2rem;">
      <h3 style="margin: 0; color: white; display: flex; align-items: center; gap: 0.5rem;"><span style="font-size: 1.2rem;">✨</span> Lifetime Achievements</h3>
      <% if (isOwnerOrAdmin) { %>
        <a href="/manage/studio/<%= studio.id %>" style="font-size: 0.8rem; color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 0.25rem;">
          <svg width="12" height="12" fill="currentColor" viewBox="0 0 16 16"><path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/><path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z"/></svg>
          Customize
        </a>
      <% } %>
    </div>
    <div class="quick-stats grid"
      style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 3rem;">
      <% if (studio.prefs.show_total_awards || isOwnerOrAdmin) { %>
      <div class="card glass-card" style="text-align: center; min-height: auto; padding: 1.5rem; position: relative;">
        <% if (!studio.prefs.show_total_awards && isOwnerOrAdmin) { %><div style="position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; background: rgba(239, 68, 68, 0.2); color: #f87171; padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(239, 68, 68, 0.3);" title="Hidden from Public">Hidden</div><% } %>
        <h4 style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">Total Awards</h4>
        <p style="font-size: 1.8rem; font-weight: 800; color: white; margin: 0.5rem 0 0.25rem 0;">
          <%= quickStats.totalAwards %>
        </p>
        <% if (quickStats.sinceYear) { %>
          <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">since <%= quickStats.sinceYear %></p>
        <% } %>
      </div>
      <% } %>
      <% if (typeof user !== 'undefined' && user) { %>
      <div class="card glass-card" style="text-align: center; min-height: auto; padding: 1.5rem; position: relative;">
        <div style="position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; background: rgba(59, 130, 246, 0.2); color: #60a5fa; padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(59, 130, 246, 0.3);" title="Visible to Registered Users">Users Only</div>
        <h4 style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">Events Attended</h4>
        <p style="font-size: 2.5rem; font-weight: 800; color: white; margin: 0.5rem 0 0;">
          <%= quickStats.totalEvents %>
        </p>
      </div>
      <% } %>

      <% if (studio.prefs.show_1st_place_finishes || isOwnerOrAdmin) { %>
      <a href="/studio/<%= studio.id %>/first-places" class="card glass-card" style="text-align: center; min-height: auto; padding: 1.5rem; position: relative; text-decoration: none; display: block; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 25px rgba(251, 191, 36, 0.15)';" onmouseout="this.style.transform='none'; this.style.boxShadow='var(--card-shadow)';">
        <% if (!studio.prefs.show_1st_place_finishes && isOwnerOrAdmin) { %><div style="position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; background: rgba(239, 68, 68, 0.2); color: #f87171; padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(239, 68, 68, 0.3);" title="Hidden from Public">Hidden</div><% } %>
        <h4 style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">1st Place Finishes <span style="font-size: 0.8rem; vertical-align: middle;">&rarr;</span></h4>
        <p style="font-size: 2.5rem; font-weight: 800; color: #fbbf24; margin: 0.5rem 0 0;">
          <%= quickStats.firstPlaceCount %>
        </p>
      </a>
      <% } %>

      <% if (quickStats.scholarshipCount > 0 || isOwnerOrAdmin) { %>
      <div class="card glass-card" style="text-align: center; min-height: auto; padding: 1.5rem; position: relative;">
        <h4 style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">Scholarships & Invites</h4>
        <p style="font-size: 2.5rem; font-weight: 800; color: #a855f7; margin: 0.5rem 0 0;">
          <%= quickStats.scholarshipCount %>
        </p>
      </div>
      <% } %>

      <% if (studio.prefs.show_1st_place_this_year || isOwnerOrAdmin) { %>
      <div class="card glass-card" style="text-align: center; min-height: auto; padding: 1.5rem; position: relative;">
        <% if (!studio.prefs.show_1st_place_this_year && isOwnerOrAdmin) { %><div style="position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; background: rgba(239, 68, 68, 0.2); color: #f87171; padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(239, 68, 68, 0.3);" title="Hidden from Public">Hidden</div><% } %>
        <h4 style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">1st Place (This Year)</h4>
        <p style="font-size: 2.5rem; font-weight: 800; color: #fbbf24; margin: 0.5rem 0 0;">
          <%= quickStats.firstPlaceCountThisYear %>
        </p>
      </div>
      <% } %>
      <% if (typeof user !== 'undefined' && user) { %>
      <div class="card glass-card" style="text-align: center; min-height: auto; padding: 1.5rem; position: relative;">
        <div style="position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; background: rgba(59, 130, 246, 0.2); color: #60a5fa; padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(59, 130, 246, 0.3);" title="Visible to Registered Users">Users Only</div>
        <h4 style="color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">Past 5 Years</h4>
        <p style="font-size: 1.25rem; font-weight: 700; color: white; margin: 0.5rem 0 0.25rem 0;">
          <%= quickStats.awardsPast5Years %> Awards
        </p>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">across <%= quickStats.eventsPast5Years %> events</p>
      </div>
      <% } %>
      <% if (studio.prefs.show_this_year || isOwnerOrAdmin) { %>
      <div class="card glass-card" style="text-align: center; min-height: auto; padding: 1.5rem; background: rgba(236, 72, 153, 0.05); border-color: rgba(236, 72, 153, 0.2); position: relative;">
        <% if (!studio.prefs.show_this_year && isOwnerOrAdmin) { %><div style="position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; background: rgba(239, 68, 68, 0.2); color: #f87171; padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(239, 68, 68, 0.3);" title="Hidden from Public">Hidden</div><% } %>
        <h4 style="color: var(--primary); font-size: 0.85rem; text-transform: uppercase;">This Year</h4>
        <p style="font-size: 1.5rem; font-weight: 800; color: white; margin: 0.5rem 0 0.25rem 0;">
          <%= quickStats.awardsThisYear %> Awards
        </p>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">across <%= quickStats.eventsThisYear %> events</p>
      </div>
      <% } %>
    </div>

    <% if (hallOfFame && hallOfFame.length > 0) { %>
      <div style="margin-bottom: 3rem;">
        <h2 style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem;"><span style="font-size: 1.5rem;">👑</span> Hall of Fame</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
          <% hallOfFame.forEach(award => { %>
            <div class="card glass-card premium-award-border" style="padding: 1.5rem; text-align: center; position: relative; overflow: hidden; background: linear-gradient(145deg, rgba(255,255,255,0.05) 0%, rgba(0,0,0,0.2) 100%);">
              <div style="position: absolute; top: -15px; right: -15px; font-size: 5rem; opacity: 0.05; text-shadow: 0 0 20px var(--accent-gold);"><%= getPremiumDetails(award).icon %></div>
              <div style="font-size: 0.75rem; color: var(--primary); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.5rem;"><%= award.event_year %> <%= award.org_name %></div>
              <h4 style="margin: 0 0 0.5rem 0; font-size: 1.1rem; color: white;"><%= award.performance_name %></h4>
              <p style="margin: 0; color: #fbbf24; font-weight: 800; font-size: 0.95rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                <%= formatPlacement(award) %> - <%= award.award_type || award.category %>
              </p>
              <% if (award.dancers && award.dancers.length > 0) { %>
                <p style="margin: 0.75rem 0 0 0; font-size: 0.8rem; color: var(--text-muted); line-height: 1.4;"><%= award.dancers.map(d => d.name).join(', ') %></p>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div class="awards-list">
      <% if (groupedData.length===0) { %>
        <div class="card glass-card">
          <p style="text-align: center;">No awards found for this studio yet.</p>
        </div>
        <% } else { %>

          <!-- Yearly Tabs -->
          <div class="tabs-container">
            <ul class="year-tabs" id="yearTabs">
              <% groupedData.forEach(function(yearGroup, index) { %>
                <li class="tab-item <%= index === 0 ? 'active' : '' %>" data-target="year-<%= yearGroup.year %>" data-loaded="<%= yearGroup.isLoaded %>" onclick="loadYear('<%= studio.id %>', '<%= yearGroup.year %>', this)">
                  <%= yearGroup.year %>
                </li>
                <% }); %>
            </ul>
          </div>

          <!-- Year Content Sections -->
          <div class="tab-content-container" style="margin-top: 2rem;">
            <% groupedData.forEach(function(yearGroup, index) { %>
              <div class="tab-pane <%= index === 0 ? 'active' : '' %>" id="year-<%= yearGroup.year %>">

                <% if (yearGroup.isLoaded) { %>
                  <%- include('partials/studio_year_events', { events: yearGroup.events }) %>
                <% } else { %>
                  <div class="loading-spinner" style="text-align: center; padding: 4rem 2rem;">
                    <div style="display: inline-block; width: 40px; height: 40px; border: 4px solid rgba(255,255,255,0.1); border-radius: 50%; border-top-color: var(--primary); animation: spin 1s ease-in-out infinite;"></div>
                    <p style="color: var(--text-muted); margin-top: 1rem;">Loading awards for <%= yearGroup.year %>...</p>
                  </div>
                <% } %>

              </div>
              <% }); %>
          </div>

          <% } %>
    </div>

    <% if (alumni && alumni.length >= 5) { %>
      <div style="margin-top: 4rem; margin-bottom: 2rem;">
        <h2 style="display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 1rem;"><span style="font-size: 1.5rem;">🎓</span> Alumni Legacy</h2>
        <p style="color: var(--text-muted); margin-bottom: 2rem;">Showcasing the incredible dancers who have trained and graduated from <%= studio.name %>.</p>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem;">
          <% alumni.forEach(a => { %>
            <div class="card glass-card" style="text-align: center; padding: 1.5rem; transition: transform 0.2s ease;">
              <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, rgba(236, 72, 153, 0.2), rgba(79, 70, 229, 0.2)); margin: 0 auto 1rem auto; display: flex; align-items: center; justify-content: center; border: 2px solid rgba(255,255,255,0.1); overflow: hidden;">
                <% if (a.headshot_url) { %>
                  <img src="<%= a.headshot_url %>" style="width: 100%; height: 100%; object-fit: cover;">
                <% } else { %>
                  <span style="font-size: 2rem;">👤</span>
                <% } %>
              </div>
              <h4 style="margin: 0 0 0.5rem 0; color: white;"><% if (a.unique_id) { %><a href="/dancer/<%= a.unique_id %>" style="color: inherit; text-decoration: none;"><%= a.name %></a><% } else { %><%= a.name %><% } %></h4>
              <span class="badge" style="background: rgba(255,255,255,0.1); color: var(--text-muted);">Class of <%= a.graduation_year %></span>
              <% if (a.notes) { %>
                <p style="margin: 0.75rem 0 0 0; font-size: 0.8rem; color: var(--primary);"><%= a.notes %></p>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
    
  </div>

  <!-- Benefits Modal -->
  <div id="benefits-modal"
    style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 9999; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease;">
    <div class="card glass-card"
      style="position: relative; max-width: 500px; width: 90%; padding: 2.5rem; transform: scale(0.95); transition: transform 0.3s ease;">
      <button onclick="closeBenefitsModal()"
        style="position: absolute; top: 1rem; right: 1rem; background: transparent; border: none; color: white; font-size: 1.5rem; cursor: pointer;">&times;</button>
      <h2
        style="margin-top: 0; margin-bottom: 1.5rem; color: var(--primary); display: flex; align-items: center; gap: 0.5rem;">
        ✨ Why Claim Your Studio?</h2>

      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.25rem;">
        <li style="display: flex; align-items: flex-start; gap: 1rem;">
          <span style="font-size: 1.5rem;">📈</span>
          <div>
            <strong style="display: block; font-size: 1.1rem; margin-bottom: 0.25rem; color: white;">Embed Awards on
              Your Site</strong>
            <span style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.4; display: block;">Showcase your
              dancers' achievements directly on your own website using our customizable widget.</span>
          </div>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 1rem;">
          <span style="font-size: 1.5rem;">🎛️</span>
          <div>
            <strong style="display: block; font-size: 1.1rem; margin-bottom: 0.25rem; color: white;">Control Your Dashboard</strong>
            <span style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.4; display: block;">Choose exactly which statistic cards you want to display on your public studio page.</span>
          </div>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 1rem;">
          <span style="font-size: 1.5rem;">🎨</span>
          <div>
            <strong style="display: block; font-size: 1.1rem; margin-bottom: 0.25rem; color: white;">Customize Your
              Profile</strong>
            <span style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.4; display: block;">Add your
              studio's logo, cover photo, bio, contact details, and social media links to stand out.</span>
          </div>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 1rem;">
          <span style="font-size: 1.5rem;">📝</span>
          <div>
            <strong style="display: block; font-size: 1.1rem; margin-bottom: 0.25rem; color: white;">Manage Your
              Awards</strong>
            <span style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.4; display: block;">Correct any
              mistakes in award records, add missing records, update missing dancer names, and keep your history
              accurate.</span>
          </div>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 1rem;">
          <span style="font-size: 1.5rem;">📊</span>
          <div>
            <strong style="display: block; font-size: 1.1rem; margin-bottom: 0.25rem; color: white;">Access Exclusive
              Analytics</strong>
            <span style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.4; display: block;">See how many
              people are viewing your studio's profile and tracking your success.</span>
          </div>
        </li>
      </ul>

      <div style="margin-top: 2.5rem; text-align: center;">
        <button class="btn" onclick="closeBenefitsModal(); alert('Claim process coming soon!')"
          style="background: var(--primary); color: white; border: none; padding: 0.75rem 2rem; font-size: 1.1rem; font-weight: 600; border-radius: 8px; cursor: pointer; width: 100%; box-shadow: 0 4px 15px rgba(236, 72, 153, 0.4);">Claim
          Your Studio Now</button>
      </div>
    </div>
  </div>

  <!-- Dancer Claim Modal -->
  <div id="claim-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 9999; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease;">
    <div class="card glass-card" style="position: relative; max-width: 500px; width: 90%; padding: 2.5rem; transform: scale(0.95); transition: transform 0.3s ease;">
      <button onclick="closeClaimModal()" style="position: absolute; top: 1rem; right: 1rem; background: transparent; border: none; color: white; font-size: 1.5rem; cursor: pointer;">&times;</button>
      <h2 style="margin-top: 0; margin-bottom: 1.5rem; color: var(--primary);">Claim Award</h2>
      <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Enter your studio's secret join code to request verification from your studio director.</p>
      
      <form id="claim-form" style="display: flex; flex-direction: column; gap: 1.5rem;">
        <input type="hidden" id="claim_award_id" name="award_id">
        <input type="hidden" name="studio_id" value="<%= studio.id %>">
        
        <div id="step-1-identity">
          <div style="background: rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1);">
            <h4 style="margin: 0 0 1rem 0; color: white;">Your Identity</h4>
            <div>
              <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-weight: 600;">Dancer Unique ID (Optional)</label>
              <input type="text" id="claim_unique_id" name="unique_id" placeholder="If you already have a profile" style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white; margin-bottom: 1rem;">
            </div>
            
            <div style="text-align: center; color: var(--text-muted); margin-bottom: 1rem;">— OR CREATE NEW —</div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
              <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-weight: 600;">Full Name</label>
                <input type="text" id="claim_name" name="name" placeholder="First Last" style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white;">
              </div>
              <div>
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-weight: 600;">Birthday</label>
                <input type="date" id="claim_birthday" name="birthday" style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white; color-scheme: dark;">
              </div>
            </div>
          </div>
          <button type="button" onclick="checkIdentity()" style="margin-top: 1.5rem; background: var(--primary); color: white; border: none; padding: 0.75rem; font-size: 1rem; font-weight: 600; border-radius: 8px; cursor: pointer; box-shadow: 0 4px 15px rgba(236, 72, 153, 0.4); width: 100%;">Continue</button>
        </div>

        <div id="step-2-code" style="display: none;">
          <h4 style="margin: 0 0 1rem 0; color: white;">Verification Required</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem;">It looks like you are not yet a verified member of this studio. Please provide the secret Join Code from your Studio Director.</p>
          <div>
            <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-weight: 600;">Studio Secret Code</label>
            <input type="text" id="claim_code" name="join_code" placeholder="e.g. A8F9K2" style="width: 100%; padding: 0.75rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2); color: white; font-family: monospace; letter-spacing: 2px;">
          </div>
          <button type="button" onclick="submitClaimFinal()" style="margin-top: 1.5rem; background: #10b981; color: white; border: none; padding: 0.75rem; font-size: 1rem; font-weight: 600; border-radius: 8px; cursor: pointer; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4); width: 100%;">Submit Claim</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    async function loadYear(studioId, year, tabElement) {
      const isLoaded = tabElement.getAttribute('data-loaded') === 'true';
      if (isLoaded) return;
      
      const pane = document.getElementById('year-' + year);
      try {
        const response = await fetch(`/api/studio/${studioId}/year/${year}`);
        const html = await response.text();
        pane.innerHTML = html;
        tabElement.setAttribute('data-loaded', 'true');
        
        // Re-initialize sortable tables for the new HTML if necessary
        if (typeof initSortableTables === 'function') {
          setTimeout(initSortableTables, 100);
        }
        
        // Auto-expand the first accordion ONLY if there is exactly 1 event
        const accordions = pane.querySelectorAll('.accordion');
        if (accordions.length === 1) {
          const firstAccordionHeader = accordions[0].querySelector('.accordion-header');
          if (firstAccordionHeader && !firstAccordionHeader.classList.contains('active')) {
            firstAccordionHeader.click();
          }
        }
      } catch (err) {
        console.error('Failed to load year:', err);
        pane.innerHTML = '<p style="text-align:center; color: #f87171;">Failed to load awards for this year. Please try again.</p>';
      }
    }

    function openBenefitsModal(e) {
      if(e) e.preventDefault();
      const modal = document.getElementById('benefits-modal');
      modal.style.display = 'flex';
      setTimeout(() => {
        modal.style.opacity = '1';
        modal.querySelector('.card').style.transform = 'scale(1)';
      }, 10);
    }

    function closeBenefitsModal() {
      const modal = document.getElementById('benefits-modal');
      modal.style.opacity = '0';
      modal.querySelector('.card').style.transform = 'scale(0.95)';
      setTimeout(() => {
        modal.style.display = 'none';
      }, 300);
    }

    function openClaimModal(awardId) {
      document.getElementById('claim_award_id').value = awardId;
      const modal = document.getElementById('claim-modal');
      modal.style.display = 'flex';
      setTimeout(() => {
        modal.style.opacity = '1';
        modal.querySelector('.card').style.transform = 'scale(1)';
      }, 10);
    }

    function closeClaimModal() {
      const modal = document.getElementById('claim-modal');
      modal.style.opacity = '0';
      modal.querySelector('.card').style.transform = 'scale(0.95)';
      setTimeout(() => {
        modal.style.display = 'none';
      }, 300);
    }

    window.onclick = function (event) {
      const bModal = document.getElementById('benefits-modal');
      const cModal = document.getElementById('claim-modal');
      if (event.target === bModal) closeBenefitsModal();
      if (event.target === cModal) closeClaimModal();
    }
    
    async function checkIdentity() {
      const form = document.getElementById('claim-form');
      const uniqueId = document.getElementById('claim_unique_id').value.trim();
      const name = document.getElementById('claim_name').value.trim();
      const studioId = form.studio_id.value;

      if (!uniqueId && !name) {
        alert("Please provide either your Unique ID or your Full Name.");
        return;
      }

      if (uniqueId) {
        // Check if already linked
        try {
          const response = await fetch(`/api/check-dancer-studio?unique_id=${encodeURIComponent(uniqueId)}&studio_id=${studioId}`);
          const result = await response.json();
          if (result.linked) {
            // Already linked, submit final immediately
            submitClaimFinal();
          } else {
            // Not linked, show code step
            document.getElementById('step-1-identity').style.display = 'none';
            document.getElementById('step-2-code').style.display = 'block';
          }
        } catch (e) {
          alert('Error checking identity.');
        }
      } else {
        // New profile, definitely not linked
        document.getElementById('step-1-identity').style.display = 'none';
        document.getElementById('step-2-code').style.display = 'block';
      }
    }

    async function submitClaimFinal() {
      const form = document.getElementById('claim-form');
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      try {
        const response = await fetch('/api/claim-award', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await response.json();
        
        if (response.ok) {
          if (result.newUniqueId) {
            alert(`Claim submitted! \n\nIMPORTANT: Your new Dancer Unique ID is:\n\n${result.newUniqueId}\n\nPlease copy and save this ID. You can use it to instantly claim other awards without needing the Studio Code again.`);
          } else {
            alert('Claim submitted successfully! It is now pending admin approval.');
          }
          closeClaimModal();
          
          // Dynamically insert the badge into all backfilled DOM cells
          const awardsToUpdate = result.backfilledAwards || [data.award_id];
          
          awardsToUpdate.forEach(a_id => {
            const cell = document.getElementById('dancers-cell-' + a_id);
            if (cell) {
              // Remove 'Company / Group' placeholder if present
              const em = cell.querySelector('em');
              if (em) em.remove();
              
              const badge = document.createElement('span');
              badge.className = 'badge-common badge-pending';
              if (result.dancerUniqueId) {
                badge.innerHTML = `<a href="/dancer/${result.dancerUniqueId}" style="color: inherit; text-decoration: none;">${result.dancerName}</a>`;
              } else {
                badge.textContent = result.dancerName;
              }
              
              // Insert before the '+ Add Me' button
              const btn = cell.querySelector('button');
              if (btn) {
                cell.insertBefore(badge, btn);
              } else {
                cell.appendChild(badge);
              }
            }
          });
        } else {
          alert(result.error || 'Failed to submit claim.');
        }
      } catch (err) {
        alert('An error occurred. Please try again.');
      }
    }
  </script>

  <%- include('partials/footer') %>