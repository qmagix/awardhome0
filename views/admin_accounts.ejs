<%- include('partials/header') %>
<div class="container" style="max-width: 1000px; margin-top: 2rem; margin-bottom: 4rem;">
  <div class="header-section">
    <h1>Account Directory & Impersonation</h1>
    <p class="subtitle">Generate one-time login links to investigate dashboards as the account owner.</p>
    <a href="/admin" class="btn btn-outline" style="margin-top: 1rem;">&larr; Back to Admin</a>
  </div>

  <div class="card glass-card" style="margin-bottom: 2rem;">
    <h2 style="color: var(--primary); margin-bottom: 1rem;">Organization Accounts</h2>
    <% if (orgs.length === 0) { %>
      <p class="text-muted">No organizations have an owner assigned yet.</p>
    <% } else { %>
      <table class="data-table" style="width: 100%;">
        <thead>
          <tr>
            <th>ID</th>
            <th>Organization Name</th>
            <th>Owner Email</th>
            <th>Events</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% orgs.forEach(o => { %>
            <tr>
              <td><%= o.id %></td>
              <td><strong><%= o.name %></strong></td>
              <td><%= o.owner_email %></td>
              <td><%= o.event_count %></td>
              <td>
                <button class="btn btn-outline" style="font-size: 0.8rem; padding: 0.25rem 0.5rem;" onclick="generateLoginLink('<%= o.owner_id %>', '/manage/org/<%= o.id %>')">Copy Login Link</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="card glass-card">
    <h2 style="color: var(--primary); margin-bottom: 1rem;">Studio Accounts</h2>
    <% if (studios.length === 0) { %>
      <p class="text-muted">No studios have been claimed yet.</p>
    <% } else { %>
      <table class="data-table" style="width: 100%;">
        <thead>
          <tr>
            <th>ID</th>
            <th>Studio Name</th>
            <th>Owner Email</th>
            <th>Awards</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% studios.forEach(s => { %>
            <tr>
              <td><%= s.id %></td>
              <td><strong><%= s.name %></strong></td>
              <td><%= s.owner_email %></td>
              <td><%= s.award_count %></td>
              <td>
                <button class="btn btn-outline" style="font-size: 0.8rem; padding: 0.25rem 0.5rem;" onclick="generateLoginLink('<%= s.owner_id %>', '/manage/studio/<%= s.id %>')">Copy Login Link</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<!-- Modal for displaying the generated link -->
<div id="link-modal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center;">
  <div class="card glass-card" style="max-width: 500px; width: 90%; text-align: center;">
    <h3 style="margin-bottom: 1rem; color: var(--accent-gold);">One-Time Login Link Generated!</h3>
    <p class="text-muted" style="margin-bottom: 1.5rem; font-size: 0.9rem;">This link will log you in as the account owner. It expires in 1 hour and can only be used once.</p>
    
    <input type="text" id="generated-link-input" class="premium-input" readonly style="width: 100%; margin-bottom: 1rem; text-align: center; font-size: 0.85rem; color: #a5b4fc;">
    
    <div style="display: flex; gap: 1rem; justify-content: center;">
      <button class="btn btn-primary" onclick="copyToClipboard()">Copy to Clipboard</button>
      <button class="btn btn-outline" onclick="document.getElementById('link-modal').style.display='none'">Close</button>
    </div>
    
    <p style="margin-top: 1rem; font-size: 0.8rem; color: #10b981;">Tip: Paste this link into a new <strong>Incognito Window</strong> so you don't lose your Superadmin session!</p>
  </div>
</div>

<script>
async function generateLoginLink(userId, targetUrl) {
  try {
    const res = await fetch('/admin/impersonate/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_id: userId, target_url: targetUrl })
    });
    const data = await res.json();
    
    if (data.success) {
      document.getElementById('generated-link-input').value = data.link;
      document.getElementById('link-modal').style.display = 'flex';
    } else {
      alert('Error generating link: ' + data.error);
    }
  } catch (e) {
    alert('Failed to connect to server.');
  }
}

function copyToClipboard() {
  const input = document.getElementById('generated-link-input');
  input.select();
  input.setSelectionRange(0, 99999); // For mobile devices
  navigator.clipboard.writeText(input.value)
    .then(() => {
      alert("Link copied to clipboard! Open an Incognito window and paste it.");
    })
    .catch(err => {
      alert("Failed to copy. Please copy it manually.");
    });
}
</script>
<%- include('partials/footer') %>
