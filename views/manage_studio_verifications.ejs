<%- include('partials/header') %>

<div class="container" style="margin-top: 4rem; display: flex; gap: 2rem;">
  
  <!-- Sidebar Navigation -->
  <div style="width: 250px; flex-shrink: 0;">
    <div class="card glass-card" style="padding: 1.5rem; position: sticky; top: 2rem;">
      <h3 style="margin-top: 0; color: var(--primary); font-size: 1.1rem;">Management</h3>
      <ul style="list-style: none; padding: 0; margin: 1rem 0 0 0; display: flex; flex-direction: column; gap: 0.5rem;">
        <li>
          <a href="/manage/studio/<%= studio.id %>" style="display: block; padding: 0.75rem 1rem; border-radius: 6px; text-decoration: none; color: var(--text-muted); transition: background 0.2s;">
            👤 Profile & Customization
          </a>
        </li>
        <li>
          <a href="/manage/studio/<%= studio.id %>/roster" style="display: block; padding: 0.75rem 1rem; border-radius: 6px; text-decoration: none; color: var(--text-muted); transition: background 0.2s;">
            👥 Dancer Roster
          </a>
        </li>
        <li>
          <a href="/manage/studio/<%= studio.id %>/awards" style="display: block; padding: 0.75rem 1rem; border-radius: 6px; text-decoration: none; color: var(--text-muted); transition: background 0.2s;">
            🏆 Awards Editor
          </a>
        </li>
        <li>
          <a href="/manage/studio/<%= studio.id %>/widget" style="display: block; padding: 0.75rem 1rem; border-radius: 6px; text-decoration: none; color: var(--text-muted); transition: background 0.2s;">
            📈 Widget Builder
          </a>
        </li>
        <li>
          <a href="/manage/studio/<%= studio.id %>/verifications" style="display: block; padding: 0.75rem 1rem; border-radius: 6px; text-decoration: none; color: white; background: rgba(236, 72, 153, 0.1); border-left: 3px solid var(--primary); font-weight: 600;">
            ✅ Pending Verifications
          </a>
        </li>
      </ul>
      
      <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.1);">
        <a href="/studio/<%= studio.id %>" style="color: var(--primary); text-decoration: none; font-size: 0.9rem;">&larr; Back to Public Profile</a>
      </div>
    </div>
  </div>

  <!-- Main Content Area -->
  <div style="flex-grow: 1;">
    <div class="header-section" style="margin-bottom: 2rem;">
      <h1>Pending Verifications</h1>
      <p class="subtitle">Review and approve requests from dancers who claimed they were in your routines.</p>
    </div>

    <% if (pendingAwards.length === 0) { %>
      <div class="card glass-card" style="text-align: center; padding: 4rem 2rem;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">✅</div>
        <h3 style="margin: 0 0 0.5rem 0; color: white;">All Caught Up!</h3>
        <p style="color: var(--text-muted); margin: 0;">There are no pending award claims requiring your review.</p>
      </div>
    <% } else { %>
      <div class="card glass-card" style="padding: 0; margin-bottom: 2rem;">
        <div style="padding: 1rem; border-bottom: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center;">
          <h3 style="margin: 0;">Pending Award Claims</h3>
          <div style="display: flex; gap: 0.5rem;">
            <button onclick="submitBulkAction('award', 'approve')" style="background: rgba(16, 185, 129, 0.2); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-weight: 600;">Approve Selected</button>
            <button onclick="submitBulkAction('award', 'deny')" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-weight: 600;">Deny Selected</button>
          </div>
        </div>
        <div style="overflow-x: auto;">
          <table class="table" style="margin: 0;">
            <thead>
              <tr>
                <th style="width: 40px;"><input type="checkbox" onclick="toggleAll('award-checkbox', this)"></th>
                <th>Dancer</th>
                <th>Event</th>
                <th>Performance</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% pendingAwards.forEach(function(req) { %>
                <tr>
                  <td><input type="checkbox" class="award-checkbox" value="<%= req.link_id %>" style="transform: scale(1.2);"></td>
                  <td>
                    <strong><%= req.dancer_name %></strong>
                    <% if (req.unique_id) { %>
                      <br><small style="color: var(--text-muted);">ID: <%= req.unique_id %></small>
                    <% } else { %>
                      <br><small style="color: #fbbf24;">New Profile Requested</small>
                    <% } %>
                  </td>
                  <td>
                    <%= req.event_name %>
                    <br><small style="color: var(--text-muted);"><%= req.year %></small>
                  </td>
                  <td>
                    <%= req.performance_name %>
                    <br><small style="color: var(--text-muted);"><%= req.award_type %></small>
                  </td>
                  <td>
                    <div style="display: flex; gap: 0.5rem;">
                      <form action="/manage/studio/<%= studio.id %>/verifications/award/<%= req.link_id %>/approve" method="POST" style="margin: 0;">
                        <button type="submit" style="background: rgba(16, 185, 129, 0.2); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-weight: 600;">Approve</button>
                      </form>
                      <form action="/manage/studio/<%= studio.id %>/verifications/award/<%= req.link_id %>/deny" method="POST" style="margin: 0;">
                        <button type="submit" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-weight: 600;">Deny</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <% if (pendingRoster && pendingRoster.length > 0) { %>
      <div class="card glass-card" style="padding: 0; margin-bottom: 2rem;">
        <div style="padding: 1rem; border-bottom: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: flex-start;">
          <div>
            <h3 style="margin: 0;">Pending Roster Requests</h3>
            <p style="margin: 0.2rem 0 0 0; font-size: 0.85rem; color: var(--text-muted);">These dancers requested to join your studio using your Studio Unique ID.</p>
          </div>
          <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
            <button onclick="submitBulkAction('roster', 'approve')" style="background: rgba(16, 185, 129, 0.2); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-weight: 600;">Approve Selected</button>
            <button onclick="submitBulkAction('roster', 'deny')" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-weight: 600;">Deny Selected</button>
          </div>
        </div>
        <div style="overflow-x: auto;">
          <table class="table" style="margin: 0;">
            <thead>
              <tr>
                <th style="width: 40px;"><input type="checkbox" onclick="toggleAll('roster-checkbox', this)"></th>
                <th>Dancer</th>
                <th>Requested On</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% pendingRoster.forEach(function(req) { %>
                <tr>
                  <td><input type="checkbox" class="roster-checkbox" value="<%= req.link_id %>" style="transform: scale(1.2);"></td>
                  <td>
                    <strong><%= req.dancer_name %></strong>
                    <br><small style="color: var(--text-muted);">ID: <%= req.unique_id %></small>
                  </td>
                  <td style="color: var(--text-muted);">
                    <%= new Date(req.created_at || Date.now()).toLocaleDateString() %>
                  </td>
                  <td>
                    <div style="display: flex; gap: 0.5rem;">
                      <form action="/manage/studio/<%= studio.id %>/verifications/roster/<%= req.link_id %>/approve" method="POST" style="margin: 0;">
                        <button type="submit" style="background: rgba(16, 185, 129, 0.2); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-weight: 600;">Approve</button>
                      </form>
                      <form action="/manage/studio/<%= studio.id %>/verifications/roster/<%= req.link_id %>/deny" method="POST" style="margin: 0;">
                        <button type="submit" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.4rem 0.75rem; border-radius: 4px; cursor: pointer; font-weight: 600;">Deny</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script>
  function toggleAll(className, source) {
    const isChecked = source.checked;
    const checkboxes = document.querySelectorAll('.' + className);
    checkboxes.forEach(cb => cb.checked = isChecked);
  }

  async function submitBulkAction(type, action) {
    const checkboxes = document.querySelectorAll('.' + type + '-checkbox:checked');
    const linkIds = Array.from(checkboxes).map(cb => cb.value);
    
    if (linkIds.length === 0) {
      return alert('Please select at least one request.');
    }
    
    if (!confirm(`Are you sure you want to ${action} ${linkIds.length} requests?`)) {
      return;
    }

    try {
      const res = await fetch(`/api/studios/<%= studio.id %>/verifications/bulk`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type, action, linkIds })
      });
      
      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json();
        alert('Bulk action failed: ' + (err.error || 'Unknown error'));
      }
    } catch (e) {
      console.error(e);
      alert('Network error during bulk action.');
    }
  }
</script>

<%- include('partials/footer') %>
