<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Awards Widget</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #<%= bg %>;
      --primary: #<%= primaryColor %>;
      --text: <%= theme === 'dark' ? '#f3f4f6' : '#1f2937' %>;
      --text-muted: <%= theme === 'dark' ? '#9ca3af' : '#6b7280' %>;
      --card-bg: <%= theme === 'dark' ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)' %>;
      --border: <%= theme === 'dark' ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)' %>;
    }
    
    body {
      margin: 0;
      padding: 1rem;
      font-family: 'Inter', sans-serif;
      background-color: var(--bg);
      color: var(--text);
    }

    .header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border);
    }

    .header img {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--primary);
    }

    .header h2 {
      margin: 0;
      font-size: 1.2rem;
    }

    .award-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
    }

    .award-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.5rem;
    }

    .event-name {
      font-weight: 600;
      font-size: 0.9rem;
    }

    .year {
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    .performance {
      font-size: 1.1rem;
      font-weight: 800;
      margin-bottom: 0.25rem;
    }

    .dancer {
      color: var(--primary);
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }

    .badges {
      display: flex;
      gap: 0.5rem;
    }

    .badge {
      font-size: 0.75rem;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-weight: 600;
    }

    .badge-place {
      background: var(--primary);
      color: white;
    }

    .badge-type {
      background: var(--border);
      color: var(--text);
    }
    
    .footer {
      text-align: center;
      margin-top: 1.5rem;
      font-size: 0.75rem;
      color: var(--text-muted);
    }
    .footer a {
      color: var(--primary);
      text-decoration: none;
    }
  </style>
</head>
<body>

  <div class="header">
    <% if (studio.logo_url) { %>
      <img src="<%= studio.logo_url %>" alt="Logo">
    <% } %>
    <h2><%= studio.name %> Awards</h2>
  </div>

  <% if (awards.length === 0) { %>
    <p style="text-align: center; color: var(--text-muted);">No recent awards.</p>
  <% } else { %>
    <% awards.forEach(award => { %>
      <div class="award-card">
        <div class="award-header">
          <span class="event-name"><%= award.event_name %></span>
          <span class="year"><%= award.year %></span>
        </div>
        <div class="performance"><%= award.performance_name || 'Routine' %></div>
        <div class="dancer"><%= award.dancer_name || 'Group' %></div>
        <div class="badges">
          <% if (award.place) { %><span class="badge badge-place"><%= formatPlacement(award.place) %></span><% } %>
          <% if (award.award_type) { %><span class="badge badge-type"><%= award.award_type %></span><% } %>
        </div>
      </div>
    <% }) %>
  <% } %>

  <div class="footer">
    Powered by <a href="http://localhost:3000" target="_blank">Dance Awards</a>
  </div>

</body>
</html>
