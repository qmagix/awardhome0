<%- include('partials/header') %>
<div class="container">
  <div class="header-section">
    <h1>Admin Dashboard</h1>
    <p class="subtitle">Data Integrity & Investigation Tools</p>
  </div>

  <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 2rem;">
    <div class="card glass-card" style="text-align: center; padding: 1.5rem;">
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Organizations</h3>
      <p style="font-size: 2rem; font-weight: 800; color: var(--primary); margin: 0;"><%= stats.orgs.toLocaleString() %></p>
    </div>
    <div class="card glass-card" style="text-align: center; padding: 1.5rem;">
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Total Events</h3>
      <p style="font-size: 2rem; font-weight: 800; color: var(--primary); margin: 0;"><%= stats.events.toLocaleString() %></p>
    </div>
    <div class="card glass-card" style="text-align: center; padding: 1.5rem;">
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Total Studios</h3>
      <p style="font-size: 2rem; font-weight: 800; color: var(--primary); margin: 0;"><%= stats.studios.toLocaleString() %></p>
      <p style="font-size: 0.8rem; color: #10b981; margin-top: 0.5rem;"><%= stats.claimedStudios.toLocaleString() %> Claimed</p>
    </div>
    <div class="card glass-card" style="text-align: center; padding: 1.5rem;">
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Total Dancers</h3>
      <p style="font-size: 2rem; font-weight: 800; color: var(--primary); margin: 0;"><%= stats.dancers.toLocaleString() %></p>
      <p style="font-size: 0.8rem; color: #10b981; margin-top: 0.5rem;"><%= stats.claimedDancers.toLocaleString() %> Claimed</p>
    </div>
    <div class="card glass-card" style="text-align: center; padding: 1.5rem;">
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Total Awards</h3>
      <p style="font-size: 2rem; font-weight: 800; color: var(--primary); margin: 0;"><%= stats.awards.toLocaleString() %></p>
    </div>
    <div class="card glass-card" <%- `style="text-align: center; padding: 1.5rem; border-color: ${stats.pendingClaims > 0 ? 'rgba(239, 68, 68, 0.4)' : 'rgba(255,255,255,0.1)'};"` %>>
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Pending Claims</h3>
      <p <%- `style="font-size: 2rem; font-weight: 800; margin: 0; color: ${stats.pendingClaims > 0 ? '#ef4444' : 'var(--text-color)'};"` %>><%= stats.pendingClaims %></p>
      <% if (stats.pendingClaims > 0) { %>
        <a href="/admin/claims" style="font-size: 0.8rem; color: #ef4444; display: block; margin-top: 0.5rem; text-decoration: none;">Review Now &rarr;</a>
      <% } %>
    </div>
    <div class="card glass-card" style="text-align: center; padding: 1.5rem;">
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Studios > 15 Awards</h3>
      <p style="font-size: 2rem; font-weight: 800; color: var(--primary); margin: 0;"><%= stats.studiosWithManyAwards.toLocaleString() %></p>
    </div>
    <div class="card glass-card" style="text-align: center; padding: 1.5rem;">
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Studios w/ Email</h3>
      <p style="font-size: 2rem; font-weight: 800; color: var(--primary); margin: 0;"><%= stats.studiosWithEmail.toLocaleString() %></p>
    </div>
    <div class="card glass-card" style="text-align: center; padding: 1.5rem;">
      <h3 style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 1px;">Marketing Target</h3>
      <p style="font-size: 2rem; font-weight: 800; color: var(--primary); margin: 0;"><%= stats.marketingStudiosCount.toLocaleString() %></p>
      <a href="/admin/marketing/studios" style="font-size: 0.8rem; color: #10b981; display: block; margin-top: 0.5rem; text-decoration: none;">View List &rarr;</a>
    </div>
  </div>

  <div style="margin-top: 3rem; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1);">
    <h2 style="margin: 0; color: white;">Quick Directories</h2>
  </div>
  <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
    <!-- Compare Studios Tool -->
    <div class="card glass-card">
      <h3 style="color: var(--primary); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">🏢 Studio Directory</h3>
      <p class="sub-text" style="margin-bottom: 1.5rem;">Launch the Selection Directory to view studios, compare histories, or inspect data.</p>
      <a href="/admin/studios" class="btn btn-primary" style="display: block; text-align: center;">Open Studio Directory</a>
    </div>

    <!-- Manage Organizations -->
    <div class="card glass-card">
      <h3 style="color: var(--primary); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">🏆 Organization Directory</h3>
      <p class="sub-text" style="margin-bottom: 1.5rem;">View, add, and edit the list of competition organizations (e.g. KAR, NYCDA).</p>
      <a href="/admin/orgs" class="btn btn-primary" style="display: block; text-align: center;">Open Org Directory</a>
    </div>

    <!-- Accounts & Impersonation -->
    <div class="card glass-card">
      <h3 style="color: var(--accent-gold); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">🔑 Account Impersonation</h3>
      <p class="sub-text" style="margin-bottom: 1.5rem;">Generate one-time links to login as specific Organizations or Studios to test dashboards.</p>
      <a href="/admin/accounts" class="btn btn-outline" style="display: block; text-align: center; border-color: var(--accent-gold); color: var(--accent-gold);">Open Accounts Directory</a>
    </div>

    <!-- Dancer Search -->
    <div class="card glass-card">
      <h3 style="color: #a855f7; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">🩰 Global Dancer Search</h3>
      <p class="sub-text" style="margin-bottom: 1.5rem;">Search the global database by dancer name and an optional studio name prefix to inspect their profile.</p>
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <input type="text" id="adminDancerSearchName" class="premium-input" placeholder="Dancer Name (e.g. Jane Doe)...">
        <input type="text" id="adminDancerSearchStudio" class="premium-input" placeholder="Studio Prefix (e.g. Elite)...">
      </div>
      <div id="adminDancerSearchResults" style="max-height: 250px; overflow-y: auto; margin-top: 1rem; display: flex; flex-direction: column; gap: 0.5rem;">
        <div style="text-align: center; color: var(--text-muted); font-size: 0.9rem;">Type to search...</div>
      </div>
    </div>
  </div>

  <div style="margin-top: 3rem; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1);">
    <h2 style="margin: 0; color: white;">Data Integrity Operations</h2>
  </div>
  <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));">
    <!-- Merge Studios Tool -->
    <div class="card glass-card">
      <h3 style="color: #ef4444; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">⚠️ Merge Duplicate Studios</h3>
      <p class="sub-text" style="margin-bottom: 1.5rem;">Merge a duplicate studio into a primary studio. The duplicate will be deleted and its history transferred.</p>
      
      <datalist id="studio-list">
        <% allStudios.forEach(s => { %>
          <option value="<%= s.id %>"><%= s.name %></option>
        <% }); %>
      </datalist>

      <div style="display: flex; gap: 1rem; align-items: flex-end;">
        <div style="flex: 1;">
          <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.8rem;">Duplicate ID (to be deleted)</label>
          <input type="text" id="merge-studio-source" list="studio-list" class="premium-input" placeholder="e.g. 124" style="width: 100%;">
        </div>
        <div style="flex: 1;">
          <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.8rem;">Primary ID (to keep)</label>
          <input type="text" id="merge-studio-target" list="studio-list" class="premium-input" placeholder="e.g. 15" style="width: 100%;">
        </div>
        <button class="btn btn-primary" onclick="mergeStudios()" style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444;">Merge</button>
      </div>
    </div>

    <!-- Merge Dancers Tool -->
    <div class="card glass-card">
      <h3 style="color: #ef4444; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">⚠️ Merge Duplicate Dancers</h3>
      <p class="sub-text" style="margin-bottom: 1.5rem;">Merge two dancers together by their Database IDs. The duplicate will be deleted.</p>
      
      <div style="display: flex; gap: 1rem; align-items: flex-end;">
        <div style="flex: 1;">
          <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.8rem;">Duplicate ID (to be deleted)</label>
          <input type="text" id="merge-dancer-source" class="premium-input" placeholder="e.g. 5002" style="width: 100%;">
        </div>
        <div style="flex: 1;">
          <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.8rem;">Primary ID (to keep)</label>
          <input type="text" id="merge-dancer-target" class="premium-input" placeholder="e.g. 5001" style="width: 100%;">
        </div>
        <button class="btn btn-primary" onclick="mergeDancers()" style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444;">Merge</button>
      </div>
    </div>
  </div>

  <div style="margin-top: 3rem; margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1);">
    <h2 style="margin: 0; color: white;">Alerts & Investigations</h2>
  </div>
  <div class="grid">
    <!-- Flagged Studios -->
    <div class="card glass-card">
      <h3 style="color: #ef4444; margin-bottom: 1rem;">Studios Flagged for Investigation (<%= flaggedStudios.length %>)</h3>
      <% if (flaggedStudios.length === 0) { %>
        <p class="sub-text">No studios flagged.</p>
      <% } else { %>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <% flaggedStudios.forEach(s => { %>
            <li style="padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); display: flex; justify-content: space-between;">
              <a href="/studio/<%= s.id %>" style="color: var(--text-color);"><%= s.name %> (ID: <%= s.id %>)</a>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>
  </div>

</div>

<script>
  let adminSearchTimeout = null;
  const adminSearchName = document.getElementById('adminDancerSearchName');
  const adminSearchStudio = document.getElementById('adminDancerSearchStudio');
  const adminSearchResults = document.getElementById('adminDancerSearchResults');

  function triggerAdminDancerSearch() {
    clearTimeout(adminSearchTimeout);
    const q = adminSearchName.value.trim();
    const studio = adminSearchStudio.value.trim();
    
    if (q.length < 2) {
      adminSearchResults.innerHTML = '<div style="text-align: center; color: var(--text-muted); font-size: 0.9rem;">Type at least 2 characters in Name to search...</div>';
      return;
    }

    adminSearchResults.innerHTML = '<div style="text-align: center; color: var(--text-muted); font-size: 0.9rem;">Searching...</div>';

    adminSearchTimeout = setTimeout(async () => {
      try {
        const res = await fetch(`/api/dancers/search?q=${encodeURIComponent(q)}&studio=${encodeURIComponent(studio)}`);
        const dancers = await res.json();
        
        if (dancers.length === 0) {
          adminSearchResults.innerHTML = '<div style="text-align: center; color: var(--text-muted); font-size: 0.9rem;">No dancers found matching criteria.</div>';
          return;
        }

        let html = '';
        dancers.forEach(d => {
          let studiosHtml = '';
          if (d.studio_names) {
            studiosHtml = `<div style="font-size: 0.8rem; color: #fbbf24; margin-top: 0.1rem;">🏫 ${d.studio_names}</div>`;
          }

          html += `
            <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 0.75rem; border-radius: 6px; display: flex; justify-content: space-between; align-items: center; gap: 0.5rem;">
              <div style="flex-grow: 1; min-width: 0;">
                <div style="font-weight: 600; color: white; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${d.name}</div>
                ${studiosHtml}
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.1rem;">${d.award_count} awards recorded</div>
              </div>
              <a href="/manage/dancer/${d.id}" target="_blank" class="btn btn-outline" style="padding: 0.3rem 0.6rem; font-size: 0.75rem; flex-shrink: 0; border-color: #a855f7; color: #a855f7;">Dashboard</a>
            </div>
          `;
        });
        adminSearchResults.innerHTML = html;
      } catch (err) {
        adminSearchResults.innerHTML = '<div style="text-align: center; color: #ef4444; font-size: 0.9rem;">Error searching database.</div>';
      }
    }, 400);
  }

  adminSearchName.addEventListener('input', triggerAdminDancerSearch);
  adminSearchStudio.addEventListener('input', triggerAdminDancerSearch);

async function mergeStudios() {
  const sourceId = document.getElementById('merge-studio-source').value;
  const targetId = document.getElementById('merge-studio-target').value;
  
  if (!sourceId || !targetId || sourceId === targetId) {
    return alert('Please enter valid, distinct IDs.');
  }
  if (!confirm('Are you absolutely sure? This action cannot be undone. The source studio will be deleted forever.')) return;

  try {
    const res = await fetch('/api/merge/studios', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sourceId, targetId })
    });
    const data = await res.json();
    if (data.success) {
      alert('Studios merged successfully!');
      window.location.reload();
    } else {
      alert('Error: ' + data.error);
    }
  } catch (e) {
    alert('Failed to merge studios: ' + e.message);
  }
}

async function mergeDancers() {
  const sourceId = document.getElementById('merge-dancer-source').value;
  const targetId = document.getElementById('merge-dancer-target').value;
  
  if (!sourceId || !targetId || sourceId === targetId) {
    return alert('Please enter valid, distinct IDs.');
  }
  if (!confirm('Are you absolutely sure? This action cannot be undone. The source dancer will be deleted forever.')) return;

  try {
    const res = await fetch('/api/merge/dancers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sourceId, targetId })
    });
    const data = await res.json();
    if (data.success) {
      alert('Dancers merged successfully!');
      window.location.reload();
    } else {
      alert('Error: ' + data.error);
    }
  } catch (e) {
    alert('Failed to merge dancers: ' + e.message);
  }
}
</script>

<%- include('partials/footer') %>
