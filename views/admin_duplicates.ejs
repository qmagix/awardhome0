<%- include('partials/header') %>

<div class="container" style="max-width: 1200px; margin: 2rem auto; padding: 0 1rem;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1>Studio Duplicates</h1>
    <div style="display: flex; gap: 1rem;">
      <span class="badge" style="background: rgba(16, 185, 129, 0.2); color: #10b981; font-size: 1rem; padding: 0.5rem 1rem;">
        Total Studios: <%= totalStudios.toLocaleString() %>
      </span>
      <span class="badge" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; font-size: 1rem; padding: 0.5rem 1rem;">
        Suspected Groups: <%= duplicateGroupsCount %>
      </span>
    </div>
  </div>

  <div class="glass-card" style="padding: 2rem;">
    <p style="color: var(--text-muted); margin-bottom: 2rem;">
      The following groups contain studios where one name is an exact case-insensitive prefix of another. Review them below and use the Compare tool to merge verified duplicates.
    </p>

    <% if (groupedDuplicates.length === 0) { %>
      <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
        <h3>No Suspected Duplicates Found</h3>
        <p>Your studio database looks incredibly clean!</p>
      </div>
    <% } else { %>
      <div class="grid" style="grid-template-columns: 1fr;">
        <% groupedDuplicates.forEach(group => { %>
          <div class="card" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.1); margin-bottom: 1rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
              <div>
                <h3 style="color: var(--primary); margin-bottom: 0.5rem;"><%= group.base.name %></h3>
                <ul style="list-style: none; padding: 0; margin: 0; color: var(--text-muted);">
                  <% group.matches.forEach(match => { %>
                    <li style="margin-bottom: 0.25rem;">↳ <%= match.name %></li>
                  <% }); %>
                </ul>
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <% group.matches.forEach(match => { %>
                  <a href="/admin/compare/studios?id1=<%= group.base.id %>&id2=<%= match.id %>" class="btn btn-warning" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;" target="_blank">
                    Compare with <%= match.name %>
                  </a>
                <% }); %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
